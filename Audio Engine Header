#ifndef AUDIO_ENGINE_HPP
#define AUDIO_ENGINE_HPP

#include <alsa/asoundlib.h>
#include <thread>
#include <atomic>
#include <vector>
#include "AudioSource.hpp"

/**
 * @brief ALSA Audio Engine Manager.
 * Handles the lifecycle of the audio hardware and the real-time playback thread.
 */
class AudioEngine {
public:
    AudioEngine(AudioSource* source);
    ~AudioEngine();

    /**
     * @brief Initializes the ALSA hardware.
     * @param device Device name, defaults to "default".
     * @param rate Sample rate in Hz.
     * @return true if initialization succeeded.
     */
    bool init(const char* device = "default", unsigned int rate = 44100);

    /**
     * @brief Starts the background playback thread.
     */
    void start();

    /**
     * @brief Stops the playback thread and cleans up.
     */
    void stop();

private:
    /**
     * @brief The worker thread function.
     * Contains the event-driven loop triggered by blocking I/O.
     */
    void playbackWorker();
    
    /**
     * @brief Attempts to recover the PCM stream from errors like Underrun.
     * @param err The negative error code returned by ALSA functions.
     */
    void recoverFromError(int err);

    snd_pcm_t* pcmHandle = nullptr;     // ALSA PCM handle
    AudioSource* audioSource = nullptr; // Pointer to the data provider
    
    std::thread workerThread;           // C++11 thread for playback
    std::atomic<bool> running{false};   // Atomic flag for thread control

    unsigned int sampleRate = 44100;    
    const snd_pcm_uframes_t periodSize = 512; // Buffer chunk size (latency control)
};

#endif
