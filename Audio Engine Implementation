#include "AudioEngine.hpp"
#include <iostream>
#include <pthread.h>
#include <sched.h>

AudioEngine::AudioEngine(AudioSource* source) : audioSource(source) {}

AudioEngine::~AudioEngine() {
    stop();
    if (pcmHandle) {
        snd_pcm_close(pcmHandle);
    }
}

bool AudioEngine::init(const char* device, unsigned int rate) {
    sampleRate = rate;
    int err;

    // Open PCM stream for playback (Lecture 3, Page 8)
    if ((err = snd_pcm_open(&pcmHandle, device, SND_PCM_STREAM_PLAYBACK, 0)) < 0) {
        std::cerr << "PCM open error: " << snd_strerror(err) << std::endl;
        return false;
    }

    /**
     * Set Hardware Parameters.
     * Using FLOAT_LE (Little Endian) for 32-bit floating point processing.
     * Interleaved access: Left, Right, Left, Right...
     */
    if ((err = snd_pcm_set_params(pcmHandle,
                                  SND_PCM_FORMAT_FLOAT_LE,
                                  SND_PCM_ACCESS_RW_INTERLEAVED,
                                  2,             // 2 channels (Stereo)
                                  sampleRate,
                                  1,             // Allow software resampling
                                  500000)) < 0) { // 0.5s hardware buffer
        std::cerr << "Set params error: " << snd_strerror(err) << std::endl;
        return false;
    }

    return true;
}

void AudioEngine::start() {
    if (running) return;
    running = true;
    // Launch thread using STL (Lecture 3, Page 6)
    workerThread = std::thread(&AudioEngine::playbackWorker, this);
}

void AudioEngine::stop() {
    running = false;
    if (workerThread.joinable()) {
        workerThread.join();
    }
}

void AudioEngine::playbackWorker() {
    /**
     * 1. Set Real-Time Priority (SCHED_FIFO).
     * This is crucial to prevent system jitter from causing audio dropouts.
     * Higher priority threads will preempt lower ones to meet the RT deadline.
     */
    struct sched_param param;
    param.sched_priority = 80; // High RT priority
    if (pthread_setschedparam(pthread_self(), SCHED_FIFO, &param) != 0) {
        std::cerr << "WARNING: Could not set SCHED_FIFO. Check audio group permissions." << std::endl;
    }

    // Pre-allocate buffer to avoid allocation inside the RT loop
    std::vector<float> buffer(periodSize * 2); 

    while (running) {
        // 2. Event: Fetch data via callback.
        if (audioSource) {
            audioSource->onProcessAudio(buffer, periodSize);
        }

        /**
         * 3. Blocking I/O (The "Heartbeat" of the engine).
         * snd_pcm_writei blocks when the hardware buffer is full.
         * The thread is woken up by the kernel exactly when the hardware 
         * needs more samples. No usleep() or polling is required.
         */
        sframes_t frames = snd_pcm_writei(pcmHandle, buffer.data(), periodSize);

        // 4. Handle Hardware Events/Errors.
        if (frames < 0) {
            recoverFromError(static_cast<int>(frames));
        } else if (frames < static_cast<sframes_t>(periodSize)) {
            std::cerr << "Short write: only " << frames << "/" << periodSize << " frames written." << std::endl;
        }
    }
}

void AudioEngine::recoverFromError(int err) {
    if (err == -EPIPE) { 
        // Underrun occurred: Softare didn't fill the buffer in time.
        std::cerr << "Buffer Underrun (-EPIPE)! Re-preparing PCM..." << std::endl;
        snd_pcm_prepare(pcmHandle);
    } else if (err < 0) {
        std::cerr << "ALSA Error: " << snd_strerror(err) << ". Attempting recovery." << std::endl;
        snd_pcm_prepare(pcmHandle);
    }
}
